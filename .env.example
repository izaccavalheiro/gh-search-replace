# GitHub Personal Access Token (alternative to OAuth Device Flow)
# Scopes required: repo, read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# OAuth App credentials (required only for Device Flow / browser login)
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx

# Git identity written to each cloned repo's local config (overrides global git config)
# If unset, the repo inherits whatever is in your global ~/.gitconfig
GIT_ACCOUNT_NAME=Your Name
GIT_ACCOUNT_EMAIL=you@example.com
