{
  "name": "gh-search-replace",
  "version": "1.0.0",
  "description": "A production-grade CLI tool that searches GitHub code, edits matched files, and opens Pull Requests — all from your terminal.",
  "type": "module",
  "bin": {
    "gh-search-replace": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@octokit/oauth-app": "^7.0.0",
    "@octokit/rest": "^21.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.1",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
